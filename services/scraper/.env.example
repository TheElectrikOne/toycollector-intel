# Supabase
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=

# Anthropic
ANTHROPIC_API_KEY=

# Discord Webhooks
DISCORD_WEBHOOK_URL=
DISCORD_WEBHOOK_URL_PREORDERS=
DISCORD_WEBHOOK_URL_RUMORS=

# Auto-publish
# URL of deployed Next.js app (no trailing slash)
WEB_APP_URL=https://your-site.vercel.app
# Must match ADMIN_SECRET set in the Next.js app environment
ADMIN_SECRET=
# Auto-publish sources at or above this trust level (5=official brands only, 6=disable)
AUTO_PUBLISH_MIN_TRUST_LEVEL=5

# App
LOG_LEVEL=INFO
DRY_RUN=false
